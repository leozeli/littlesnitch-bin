post_install() {
    systemctl daemon-reload
    echo ":: Little Snitch daemon installed. To start and enable it:"
    echo "::   systemctl enable --now littlesnitch.service"
}

post_upgrade() {
    systemctl daemon-reload
    systemctl restart littlesnitch.service
}

pre_remove() {
    systemctl disable --now littlesnitch.service || true
}

post_remove() {
    systemctl daemon-reload
}
